# 서버
PORT=3000

# GitHub App
GITHUB_APP_ID=
# PEM 키 전체를 한 줄로 붙여넣어도 됨 (개행이 \n 리터럴로 들어와도 코드가 자동 변환함)
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_REVIEW_REQUEST_TOPIC=pr.review.requested
KAFKA_REVIEW_COMPLETED_TOPIC=pr.review.completed
KAFKA_REVIEW_FAILED_TOPIC=pr.review.failed

# Redis
REDIS_URL=redis://localhost:6379

# Discord 알림 (선택 - 비워두면 자동 비활성화, 부팅에는 영향 없음)
DISCORD_WEBHOOK_URL=
